{
  "name": "rxjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 9000",
    "build": "next build",
    "start": "next start -p 9001",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,scss,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,scss,mjs}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "ahooks": "^3.9.7",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "jose": "^6.2.3",
    "lodash": "^4.18.1",
    "next": "16.2.7",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-scan": "^0.5.7",
    "rxjs": "^7.8.2",
    "server-only": "^0.0.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "sass": "^1.100.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{css,scss,sass,json,md}": [
      "prettier --write"
    ]
  }
}
